<Window x:Class="PN_Ground_Station.AboutMe"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:PN_Ground_Station"
        mc:Ignorable="d"
        Title="About" Height="650" Width="900"
        Background="{DynamicResource BackgroundBrush}"
        WindowStartupLocation="CenterScreen">
    <Window.Resources>
        <!-- Dark Theme Colors -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#252526"/>
        <SolidColorBrush x:Key="SurfaceElevatedBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
        <SolidColorBrush x:Key="AccentHoverBrush" Color="#1C97EA"/>
        <SolidColorBrush x:Key="AccentSecondaryBrush" Color="#68217A"/>
        <SolidColorBrush x:Key="TextBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#858585"/>
        <SolidColorBrush x:Key="TextMutedBrush" Color="#6A6A6A"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>
        <SolidColorBrush x:Key="BorderLightBrush" Color="#505050"/>

        <!-- Author Card Colors -->
        <SolidColorBrush x:Key="CardBackgroundBrush" Color="#2D2D30"/>
        <SolidColorBrush x:Key="CardHoverBrush" Color="#333337"/>
        <SolidColorBrush x:Key="AvatarBorderBrush" Color="#007ACC"/>

        <!-- Status/Badge Colors -->
        <SolidColorBrush x:Key="SuccessBrush" Color="#4EC9B0"/>
        <SolidColorBrush x:Key="WarningBrush" Color="#CE9178"/>
        <SolidColorBrush x:Key="InfoBrush" Color="#569CD6"/>
        <SolidColorBrush x:Key="ErrorBrush" Color="#F48771"/>

        <!-- Social/Link Colors -->
        <SolidColorBrush x:Key="LinkBrush" Color="#4FC1FF"/>
        <SolidColorBrush x:Key="LinkHoverBrush" Color="#6DD1FF"/>

        <!-- Header/Section Colors -->
        <SolidColorBrush x:Key="HeaderBrush" Color="#1A1A1A"/>
        <SolidColorBrush x:Key="DividerBrush" Color="#404040"/>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentHoverBrush}"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Secondary Button Style -->
        <Style x:Key="SecondaryButton" TargetType="Button">
            <Setter Property="Background" Value="{StaticResource SurfaceElevatedBrush}"/>
            <Setter Property="Foreground" Value="{StaticResource TextBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="Padding" Value="16,10"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontSize" Value="14"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource CardHoverBrush}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Hyperlink Style -->
        <Style TargetType="Hyperlink">
            <Setter Property="Foreground" Value="{StaticResource LinkBrush}"/>
            <Setter Property="TextDecorations" Value="None"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Foreground" Value="{StaticResource LinkHoverBrush}"/>
                    <Setter Property="TextDecorations" Value="Underline"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <!-- Card Style -->
        <Style x:Key="AuthorCard" TargetType="Border">
            <Setter Property="Background" Value="{StaticResource CardBackgroundBrush}"/>
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrush}"/>
            <Setter Property="BorderThickness" Value="1"/>
            <Setter Property="CornerRadius" Value="8"/>
            <Setter Property="Padding" Value="30"/>
            <Setter Property="Margin" Value="20"/>
        </Style>
    </Window.Resources>


    <Grid Background="{StaticResource BackgroundBrush}">
        
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        
        
            <StackPanel>
                <TextBlock Text="💧 About Me" 
                               Foreground="{StaticResource TextBrush}" 
                               FontSize="32" FontWeight="Bold" 
                               HorizontalAlignment="Center" Margin="0,20,0,0"/>
                <TextBlock Text="Water Quality Telemetry Station" 
                               Foreground="{StaticResource TextSecondaryBrush}" 
                               FontSize="16" 
                               HorizontalAlignment="Center" 
                               Margin="0,5,0,0"/>
            </StackPanel>
       

       
        <StackPanel Grid.Row="1" Margin="0,0,0,10">
           
            <Border Style="{StaticResource AuthorCard}">
                <StackPanel>
                    
                    <Border Width="120" Height="120" 
                                CornerRadius="60" 
                                BorderBrush="{StaticResource AvatarBorderBrush}" 
                                BorderThickness="3"
                                HorizontalAlignment="Center"
                                Margin="0,0,0,20">
                        <Border.Background>
                            <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                <GradientStop Color="#007ACC" Offset="0"/>
                                <GradientStop Color="#68217A" Offset="1"/>
                            </LinearGradientBrush>
                        </Border.Background>
                        <TextBlock Text="BŚ" 
                                       Foreground="White" 
                                       FontSize="48" 
                                       FontWeight="Bold"
                                       HorizontalAlignment="Center" 
                                       VerticalAlignment="Center"/>
                    </Border>

                    
                    <TextBlock Text="Bartłomiej Ślusarz" 
                                   Foreground="{StaticResource TextBrush}" 
                                   FontSize="28" 
                                   FontWeight="Bold" 
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,5"/>

                    <TextBlock Text="Developer and Creator" 
                                   Foreground="{StaticResource TextSecondaryBrush}" 
                                   FontSize="16" 
                                   HorizontalAlignment="Center"
                                   Margin="0,0,0,20"/>

                    <!-- Divider -->
                    <Border Height="1" 
                                Background="{StaticResource DividerBrush}" 
                                Margin="0,0,0,20"/>

                    
                    <TextBlock TextWrapping="Wrap" 
                                   Foreground="{StaticResource TextBrush}" 
                                   FontSize="15" 
                                   LineHeight="24"
                                   TextAlignment="Center"
                                   Margin="20,0,20,25">
                            This Water Quality Telemetry Station application was developed with expertise 
                            in C# and WPF to operate and display real-time water quality data collection and analysis.
                    </TextBlock>

                    
                    <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,25">
                        <Border Background="{StaticResource InfoBrush}" 
                                    CornerRadius="12" 
                                    Padding="12,6" 
                                    Margin="5">
                            <TextBlock Text="C#" 
                                           Foreground="White" 
                                           FontWeight="SemiBold" 
                                           FontSize="12"/>
                        </Border>
                        <Border Background="{StaticResource SuccessBrush}" 
                                    CornerRadius="12" 
                                    Padding="12,6" 
                                    Margin="5">
                            <TextBlock Text="WPF" 
                                           Foreground="White" 
                                           FontWeight="SemiBold" 
                                           FontSize="12"/>
                        </Border>
                        <Border Background="{StaticResource WarningBrush}" 
                                    CornerRadius="12" 
                                    Padding="12,6" 
                                    Margin="5">
                            <TextBlock Text=".NET" 
                                           Foreground="White" 
                                           FontWeight="SemiBold" 
                                           FontSize="12"/>
                        </Border>
                    </WrapPanel>

                    
                    <StackPanel Orientation="Horizontal" 
                                    HorizontalAlignment="Center">
                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}" 
                                       FontSize="14" 
                                       VerticalAlignment="Center">
                                Follow me on
                        </TextBlock>
                        <TextBlock Margin="5,0,0,0" VerticalAlignment="Center">
                                <Hyperlink NavigateUri="https://github.com/barto3214" 
                                          RequestNavigate="Hyperlink_RequestNavigate">
                                    <Run Text="GitHub" FontSize="14" FontWeight="SemiBold"/>
                                </Hyperlink>
                        </TextBlock>
                    </StackPanel>
                </StackPanel>
            </Border>
        </StackPanel>
    </Grid>
</Window>