<UserControl x:Class="PN_Ground_Station.DockWindows.DataGridWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Background="#252526" BorderBrush="#3F3F46" 
                BorderThickness="0,0,0,1" Padding="15,10">
            <TextBlock Text="📜 Measurement History (Last 50)" 
                       Foreground="#CCCCCC" FontSize="14" FontWeight="Bold"/>
        </Border>

        <!-- DataGrid -->
        <DataGrid Grid.Row="1" 
                  ItemsSource="{Binding DataHistory}"
                  AutoGenerateColumns="False"
                  IsReadOnly="True"
                  GridLinesVisibility="Horizontal"
                  HeadersVisibility="Column"
                  Background="#1E1E1E"
                  Foreground="#CCCCCC"
                  BorderThickness="0"
                  RowBackground="#252526"
                  AlternatingRowBackground="#2D2D30"
                  CanUserResizeRows="False"
                  CanUserSortColumns="True">

            <DataGrid.ColumnHeaderStyle>
                <Style TargetType="DataGridColumnHeader">
                    <Setter Property="Background" Value="#3F3F46"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Setter Property="FontWeight" Value="Bold"/>
                    <Setter Property="Padding" Value="10,8"/>
                    <Setter Property="BorderThickness" Value="0,0,1,0"/>
                    <Setter Property="BorderBrush" Value="#1E1E1E"/>
                </Style>
            </DataGrid.ColumnHeaderStyle>

            <DataGrid.CellStyle>
                <Style TargetType="DataGridCell">
                    <Setter Property="BorderThickness" Value="0"/>
                    <Setter Property="Padding" Value="10,5"/>
                    <Setter Property="Foreground" Value="#CCCCCC"/>
                    <Style.Triggers>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter Property="Background" Value="#007ACC"/>
                            <Setter Property="Foreground" Value="White"/>
                        </Trigger>
                    </Style.Triggers>
                </Style>
            </DataGrid.CellStyle>

            <DataGrid.Columns>
                <DataGridTextColumn Header="Time" 
                                    Binding="{Binding ReceivedAt, StringFormat='HH:mm:ss'}" 
                                    Width="80"/>
                <DataGridTextColumn Header="Station" 
                                    Binding="{Binding StationId}" 
                                    Width="70"/>
                <DataGridTextColumn Header="pH" 
                                    Binding="{Binding Ph, StringFormat=F2}" 
                                    Width="60"/>
                <DataGridTextColumn Header="TDS (ppm)" 
                                    Binding="{Binding Tds, StringFormat=F1}" 
                                    Width="90"/>
                <DataGridTextColumn Header="Temp (°C)" 
                                    Binding="{Binding Temperature, StringFormat=F1}" 
                                    Width="90"/>
                <DataGridTextColumn Header="Conductivity (µS/cm)" 
                                    Binding="{Binding Conductivity, StringFormat=F0}" 
                                    Width="150"/>
                <DataGridTextColumn Header="Battery (V)" 
                                    Binding="{Binding BatteryVoltage, StringFormat=F2}" 
                                    Width="90"/>
                <DataGridTextColumn Header="Quality" 
                                    Binding="{Binding WaterQuality}" 
                                    Width="*"/>
            </DataGrid.Columns>
        </DataGrid>
    </Grid>
</UserControl>
