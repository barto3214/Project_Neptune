<UserControl x:Class="PN_Ground_Station.DockWindows.ControlsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="15">

            <!-- Current Readings Section -->
            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" 
                    Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="⚡ Current Readings" 
                               Foreground="#CCCCCC" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <!-- pH -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="pH:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtPh" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="txtPhStatus" Grid.Column="2" Text="" 
                                   Foreground="#007ACC" FontStyle="Italic"/>
                    </Grid>

                    <!-- TDS -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="TDS:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTds" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTdsUnit" Grid.Column="2" Text="" 
                                   Foreground="#999999"/>
                    </Grid>

                    <!-- Temperature -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Temperature:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTemp" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTempUnit" Grid.Column="2" Text="" 
                                   Foreground="#999999"/>
                    </Grid>

                    <!-- Conductivity -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Conductivity:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtCond" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="txtCondUnit" Grid.Column="2" Text="" 
                                   Foreground="#999999"/>
                    </Grid>

                    <Separator Background="#3F3F46" Margin="0,15"/>

                    <!-- Battery -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Battery:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtBattery" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="txtBatteryUnit" Grid.Column="2" Text="" 
                                   Foreground="#999999"/>
                    </Grid>

                    <!-- Water Quality -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <TextBlock Grid.Column="0" Text="Water Quality:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtQuality" Grid.Column="1" Text="--" 
                                   Foreground="#00D000" FontSize="16" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Pump Control Section -->
            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" 
                    Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="💧 Remote control" 
                               Foreground="#CCCCCC" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <Button Content="Measure" x:Name="btnMeasure" Height="40" 
                    Margin="0,5" Click="btnMeasure_Click"  IsEnabled="True"/>
                    <Button Content="Start Intake Pump" Height="40" 
                            Margin="0,5" Click="BtnStartPump_Click" IsEnabled="False"/>
                    <Button Content="Start Discharge Pump" Height="40" 
                            Margin="0,5" Click="BtnStopPump_Click" IsEnabled="False"/>
                    <Button Content="Start Measurement Cycle" Height="40" 
                            Margin="0,5" Click="BtnStartCycle_Click" IsEnabled="False"/>
                </StackPanel>
            </Border>

            <!-- System Info Section -->
            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" 
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="ℹ️ System Information" 
                               Foreground="#CCCCCC" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <TextBlock Foreground="#999999" TextWrapping="Wrap">
                        <Run Text="Station Type: "/><Run Text="Water Quality Monitor" Foreground="#CCCCCC" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Foreground="#999999" TextWrapping="Wrap" Margin="0,5,0,0">
                        <Run Text="Sensors: "/><Run Text="pH, TDS, Temp, Conductivity" Foreground="#CCCCCC"/>
                    </TextBlock>
                    <TextBlock Foreground="#999999" TextWrapping="Wrap" Margin="0,5,0,0">
                        <Run Text="Communication: "/><Run Text="NRF905 (433MHz)" Foreground="#CCCCCC"/>
                    </TextBlock>
                    <TextBlock Foreground="#999999" TextWrapping="Wrap" Margin="0,5,0,0">
                        <Run Text="Version: "/><Run Text="1.0.0-beta" Foreground="#CCCCCC"/>
                    </TextBlock>
                </StackPanel>
            </Border>
        </StackPanel>
    </ScrollViewer>
</UserControl>
