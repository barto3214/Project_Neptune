<UserControl x:Class="PN_Ground_Station.DockWindows.ControlsWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <ScrollViewer VerticalScrollBarVisibility="Auto" PreviewMouseWheel="ScrollViewer_PreviewMouseWheel">
        <StackPanel Margin="15">

            <!-- Current Readings Section -->
            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" 
                    Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="⚡ Current Readings" 
                               Foreground="#CCCCCC" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <!-- pH -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="pH:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtPh" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="txtPhStatus" Grid.Column="2" Text="" 
                                   Foreground="#007ACC" FontStyle="Italic"/>
                    </Grid>

                    <!-- TDS -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="TDS:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTds" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTdsUnit" Grid.Column="2" Text="" 
                                   Foreground="#999999"/>
                    </Grid>

                    <!-- Temperature -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Temperature:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTemp" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="txtTempUnit" Grid.Column="2" Text="" 
                                   Foreground="#999999"/>
                    </Grid>

                    <!-- Conductivity -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Conductivity:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtCond" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="20" FontWeight="Bold"/>
                        <TextBlock x:Name="txtCondUnit" Grid.Column="2" Text="" 
                                   Foreground="#999999"/>
                    </Grid>

                    <Separator Background="#3F3F46" Margin="0,15"/>

                    <!-- Battery -->
                    <Grid Margin="0,5">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Battery:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtBattery" Grid.Column="1" Text="--" 
                                   Foreground="#CCCCCC" FontSize="18" FontWeight="Bold"/>
                        <TextBlock x:Name="txtBatteryUnit" Grid.Column="2" Text="" 
                                   Foreground="#999999"/>
                    </Grid>

                    <!-- Water Quality -->
                    <Grid Margin="0,10,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="120"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Water Quality:" Foreground="#999999" FontWeight="Bold"/>
                        <TextBlock x:Name="txtQuality" Grid.Column="1" Text="--" 
                                   Foreground="#00D000" FontSize="16" FontWeight="Bold"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- Pump Control Section -->
            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" 
                    Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="💧 Water control" 
                               Foreground="#CCCCCC" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <Button Content="Start pump 1 (external)" Height="40" 
                            Margin="0,5" Click="BtnStartPump_Click"/>
                    <Button Content="Stop pump 1 (external)" Height="40" 
                            Margin="0,5" Click="BtnStopPump_Click"/>
                    <Button Content="Start Measuring cycle" x:Name="btnMeasure" Height="40" 
                            Margin="0,5" Click="btnStartMeasurementCycle_Click"/>
                    <Button Content="Start Loading Cycle (1 test-tube)" Height="40" 
                            Margin="0,5" Click="BtnStartLoadingCycle_Click"/>
                    <Button Content="Start rejecting water by pump 2 (internal)" Height="40" 
                            Margin="0,5" Click="btnStartRejectingCycle_Click"/>
                </StackPanel>
            </Border>

            <!-- Boat Control Section -->
            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" 
                    Padding="15" Margin="0,0,0,15">
                <StackPanel>
                    <TextBlock Text="🚤 Boat Control" 
                               Foreground="#CCCCCC" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,15"/>

                    <!-- Status -->
                    <Grid Margin="0,0,0,10">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="Status: " Foreground="#999999" FontWeight="Bold"
                                   VerticalAlignment="Center"/>
                        <TextBlock x:Name="txtBoatStatus" Grid.Column="1"
                                   Text="● INACTIVE" Foreground="#FF4444"
                                   FontWeight="Bold" VerticalAlignment="Center"/>
                    </Grid>

                    <!-- Activate/Deactivate -->
                    <Button x:Name="btnBoatToggle"
                            Content="▶  Activate WSAD Control"
                            Height="40" Margin="0,5"
                            Background="#007ACC" Foreground="White" FontWeight="Bold"
                            Click="BtnBoatToggle_Click"/>

                    <Separator Background="#3F3F46" Margin="0,10"/>

                    <!-- Keymap info -->
                    <TextBlock Foreground="#666666" FontSize="11" Margin="0,0,0,4"
                               Text="Keyboard layout (focus on this panel first):"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Foreground="#999999" FontSize="11" Text="W — forward"/>
                            <TextBlock Foreground="#999999" FontSize="11" Text="S — reverse"/>
                            <TextBlock Foreground="#999999" FontSize="11" Text="A — pivot left"/>
                            <TextBlock Foreground="#999999" FontSize="11" Text="D — pivot right"/>
                        </StackPanel>
                        <StackPanel Grid.Column="1">
                            <TextBlock Foreground="#999999" FontSize="11" Text="W+A — arc left"/>
                            <TextBlock Foreground="#999999" FontSize="11" Text="W+D — arc right"/>
                            <TextBlock Foreground="#999999" FontSize="11" Text="S+A/S+D — reverse arc"/>
                            <TextBlock Foreground="#FF4444" FontSize="11" FontWeight="Bold" Text="SPACE — emergency stop"/>
                        </StackPanel>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- System Info Section -->
            <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" 
                    Padding="15">
                <StackPanel>
                    <TextBlock Text="ℹ️ System Information" 
                               Foreground="#CCCCCC" FontSize="16" FontWeight="Bold"
                               Margin="0,0,0,15"/>
                    <TextBlock Foreground="#999999" TextWrapping="Wrap">
                        <Run Text="Station Type: "/><Run Text="Water Quality Monitor" Foreground="#CCCCCC" FontWeight="Bold"/>
                    </TextBlock>
                    <TextBlock Foreground="#999999" TextWrapping="Wrap" Margin="0,5,0,0">
                        <Run Text="Sensors: "/><Run Text="pH, TDS, Temp, Conductivity" Foreground="#CCCCCC"/>
                    </TextBlock>
                    <TextBlock Foreground="#999999" TextWrapping="Wrap" Margin="0,5,0,0">
                        <Run Text="Communication: "/><Run Text="NRF905 (433MHz)" Foreground="#CCCCCC"/>
                    </TextBlock>
                    <TextBlock Foreground="#999999" TextWrapping="Wrap" Margin="0,5,0,0">
                        <Run Text="Version: "/><Run Text="1.3.0" Foreground="#CCCCCC"/>
                    </TextBlock>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
