<UserControl x:Class="PN_Ground_Station.DockWindows.CameraWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">

    <Grid>
        <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" Margin="15">
            <Grid>
                <Viewbox Stretch="Uniform" Margin="50">
                    <TextBlock Text="📷" FontSize="200" 
                               Foreground="#3F3F46" 
                               HorizontalAlignment="Center" 
                               VerticalAlignment="Center"/>
                </Viewbox>

                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Camera Preview" 
                               FontSize="24" FontWeight="Bold" 
                               Foreground="#CCCCCC"
                               HorizontalAlignment="Center" 
                               Margin="0,0,0,10"/>
                    <TextBlock Text="(Feature under development)" 
                               FontSize="16" 
                               Foreground="#999999"
                               HorizontalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</UserControl>
