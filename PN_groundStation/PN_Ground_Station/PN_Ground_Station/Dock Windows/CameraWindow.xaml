<UserControl x:Class="PN_Ground_Station.DockWindows.CameraWindow"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="#1E1E1E">
    <Grid>
        <Border Background="#252526" BorderBrush="#3F3F46" BorderThickness="1" Margin="10">
            <Grid>

                <!-- Pasek połączenia - na dole -->
                <StackPanel VerticalAlignment="Bottom" HorizontalAlignment="Center"
                            Orientation="Horizontal" Margin="0,0,0,10"
                            Panel.ZIndex="1">
                    <TextBox x:Name="txtStreamUrl"
                             Text="100.95.54.57"
                             Width="120" Height="24"
                             Background="#1E1E1E" Foreground="#CCCCCC"
                             BorderBrush="#555555" Padding="4,2"
                             VerticalContentAlignment="Center"/>
                    <Button x:Name="btnConnect" Content="Conect"
                            Width="70" Height="24" Margin="5,0,0,0"
                            Padding="0"
                            Click="BtnConnect_Click"/>
                    <Button x:Name="btnDisconnect" Content="Disconnect"
                            Width="70" Height="24" Margin="4,0,0,0"
                            IsEnabled="False" Padding="0"
                            Click="BtnDisconnect_Click"/>
                    <TextBlock x:Name="txtStatus" Text="● Disconnected"
                               Foreground="#FF6666" FontWeight="Bold"
                               VerticalAlignment="Center" Margin="10,0,0,0"/>
                </StackPanel>

                <!-- Placeholder - widoczny gdy brak połączenia -->
                <Viewbox x:Name="pnlPlaceholder" Stretch="Uniform" Margin="50">
                    <TextBlock Text="📷" FontSize="200"
                               Foreground="#3F3F46"
                               HorizontalAlignment="Center"
                               VerticalAlignment="Center"/>
                </Viewbox>
                <StackPanel x:Name="pnlPlaceholderText"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="Camera Preview"
                               FontSize="24" FontWeight="Bold"
                               Foreground="#CCCCCC"
                               HorizontalAlignment="Center"
                               Margin="0,0,0,10"/>
                    <TextBlock Text="Enter wehicle IP and press connect"
                               FontSize="16"
                               Foreground="#999999"
                               HorizontalAlignment="Center"/>
                </StackPanel>

                <!-- Obraz z kamery - ukryty dopóki nie ma połączenia -->
                <Image x:Name="imgCamera"
                       Stretch="Uniform"
                       Visibility="Collapsed"/>

            </Grid>
        </Border>
    </Grid>
</UserControl>
