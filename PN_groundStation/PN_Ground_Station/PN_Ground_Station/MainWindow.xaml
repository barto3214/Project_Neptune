<Window x:Class="PN_Ground_Station.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:netdock="clr-namespace:NetDock;assembly=NetDock"
        xmlns:local="clr-namespace:PN_Ground_Station"
        mc:Ignorable="d"
        Title="Water Quality Telemetry Station" 
        Height="800" Width="1400"
        WindowState="Maximized"
        Background="#1E1E1E"
        Loaded="Window_Loaded"
        Closing="Window_Closing">

    <Window.Resources>
        <!-- Dark Theme Colors -->
        <SolidColorBrush x:Key="BackgroundBrush" Color="#1E1E1E"/>
        <SolidColorBrush x:Key="SurfaceBrush" Color="#252526"/>
        <SolidColorBrush x:Key="AccentBrush" Color="#007ACC"/>
        <SolidColorBrush x:Key="TextBrush" Color="#CCCCCC"/>
        <SolidColorBrush x:Key="BorderBrush" Color="#3F3F46"/>

        <!-- Button Style -->
        <Style TargetType="Button">
            <Setter Property="Background" Value="{StaticResource AccentBrush}"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Padding" Value="12,6"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="FontWeight" Value="SemiBold"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="0.8"/>
                </Trigger>
                <Trigger Property="IsEnabled" Value="False">
                    <Setter Property="Opacity" Value="0.5"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Top Toolbar -->
        <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1"
            Padding="15,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal">
                    <TextBlock Text="Water Quality Telemetry Station" 
                           FontSize="18" FontWeight="Bold" 
                           Foreground="{StaticResource TextBrush}" 
                           VerticalAlignment="Center"/>
                </StackPanel>

                <!-- Connection Controls -->
                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <TextBox x:Name="txtServerAddress" Width="120" Text="192.168.0.112" Margin="2"
                         VerticalContentAlignment="Center" Padding="8,4"/>
                    <TextBlock Text=":" Foreground="{StaticResource TextBrush}" 
                           VerticalAlignment="Center" Margin="2,0"/>
                    <TextBox x:Name="txtServerPort" Width="60" Text="5000" Margin="2"
                         VerticalContentAlignment="Center" Padding="8,4"/>

                    <Button x:Name="btnConnect" Content="Connect" Width="90" Margin="5,2"
                        Click="BtnConnect_Click"/>
                    <Button x:Name="btnDisconnect" Content="Disconnect" Width="90" Margin="2"
                        IsEnabled="False" Click="BtnDisconnect_Click"/>

                    <!-- Connection Indicator -->
                    <Ellipse x:Name="connectionIndicator" Width="14" Height="14" 
                         Fill="Red" Margin="15,0,5,0"/>
                    <TextBlock x:Name="txtConnectionStatus" Text="Disconnected" 
                           Foreground="{StaticResource TextBrush}" 
                           VerticalAlignment="Center" Margin="5,0"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- NetDock Surface - Main Content Area -->
        <netdock:DockSurface x:Name="dockSurface" Grid.Row="1"
                         Background="{StaticResource BackgroundBrush}"/>


        <!-- Status Bar -->
        <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" 
            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
            Padding="15,8">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <TextBlock x:Name="txtStatusMessage" Text="Ready" 
                       Foreground="{StaticResource TextBrush}" 
                       VerticalAlignment="Center"/>

                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <TextBlock Text="Last data: " 
                           Foreground="#999999" 
                           VerticalAlignment="Center"/>
                    <TextBlock x:Name="txtLastDataTime" Text="--:--:--" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                    <TextBlock Text=" | Packets: " 
                           Foreground="#999999" 
                           VerticalAlignment="Center" Margin="20,0,0,0"/>
                    <TextBlock x:Name="txtPacketCount" Text="0" 
                           Foreground="{StaticResource TextBrush}" 
                           FontWeight="Bold" 
                           VerticalAlignment="Center"/>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
